// routes/reportRoutes.js
const express = require("express");
const router = express.Router();

// GET /api/reports/monthly - Feature 1 + 3
router.get("/monthly", async (req, res) => {
  const monthlyData = await db.query(`
    SELECT MONTH(date) as month, 
           AVG(utilization) as utilization, 
           AVG(approval_rate) as approvalRate
    FROM leave_requests 
    JOIN approval_workflow ON leave_requests.id = approval_workflow.leave_id
    GROUP BY MONTH(date)
  `);
  const stats = { totalDays: 320, utilization: 78, pending: 12, approvalRate: 92 };
  res.json({ stats, monthlyData });
});

// GET /api/reports/department - Feature 2  
router.get("/department", async (req, res) => {
  const deptData = await db.query(`
    SELECT e.department, SUM(l.days) as daysUsed, e.total_leave - SUM(l.days) as daysRemaining
    FROM employee_profiles e 
    JOIN leave_requests l ON e.id = l.employee_id 
    GROUP BY e.department
  `);
  res.json({ stats: {...}, deptData });
});

// GET /api/reports/employee - Feature 4
router.get("/employee", async (req, res) => {
  const employeeHistory = await db.query(`
    SELECT e.name, e.department as dept, l.type, l.start_date as startDate, l.days, a.status
    FROM employee_profiles e 
    JOIN leave_requests l ON e.id = l.employee_id
    JOIN approval_workflow a ON l.id = a.leave_id
  `);
  res.json({ stats: {...}, employeeHistory });
});

// GET /api/reports/approval - Feature 3
router.get("/approval", async (req, res) => {
  const approvalData = await db.query(`
    SELECT status, COUNT(*) as value FROM approval_workflow GROUP BY status
  `);
  res.json({ stats: {...}, approvalData });
});
